{
  "name": "cmdcld",
  "version": "0.4.4",
  "description": "Multi-terminal Claude launcher",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "electron-vite build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.i60.cmdcld",
    "productName": "CmdCLD",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "CmdCLD-Setup.exe"
    },
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react-grid-layout": "^1.5.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "png2icons": "^2.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
